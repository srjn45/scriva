---
import '../styles/landing.css';
const base = import.meta.env.BASE_URL; // '/scriva/'
const gh = 'https://github.com/srjn45/scriva';

const values = [
  ['📄', 'Human-readable storage', 'Every collection is plain NDJSON — one JSON object per line. Inspect, grep, back up, or migrate your data with any text editor. No binary format, no hidden state.'],
  ['➕', 'Append-only & durable', 'Inserts, updates, and deletes are always new lines. Choose your fsync policy, and a CRC32C checksum on every entry catches silent on-disk bit-rot on read.'],
  ['🔌', 'gRPC + REST + embed', 'A dual API served from one binary — plus a `go get`-able storage engine you can run in-process, with zero gRPC/Prometheus/OTel dependencies.'],
  ['📦', 'Single binary', 'No JVM, no Python, no daemon zoo, no config file to get started. One small Go binary that serves, and one CLI that talks to it over a Unix socket.'],
];

const layers = [
  ['#a78bfa', 'segment log', 'append-only NDJSON files, sealed at 4 MiB'],
  ['#38bdf8', 'id index', 'in-memory O(1) lookup, checksummed on disk'],
  ['#7c3aed', 'secondary indexes', 'per-field equality + range, auto-maintained'],
  ['#3fb950', 'compactor', 'goroutine per collection merges & dedups'],
];

const api = ['insert', 'find', 'update', 'delete', 'upsert', 'update-if-rev', 'aggregate', 'watch', 'begin-tx', 'backup'];

const features = [
  ['Data model & keys', 'guides/data-model'],
  ['Queries & indexes', 'guides/queries'],
  ['Aggregations', 'guides/queries'],
  ['Transactions & CAS', 'guides/data-model'],
  ['Durability & backup', 'guides/durability-and-backup'],
  ['Replication & failover', 'guides/replication'],
  ['Embedding (Go library)', 'guides/embedding'],
  ['Client SDKs (7 langs)', 'guides/clients'],
];

const deploys = [
  ['🖥️', 'Standalone server', 'Run <code>scriva serve</code> and get gRPC on :5433 and REST on :8080 from one binary. Talk to it from any language, or from the CLI over a Unix socket.'],
  ['📚', 'Embedded library', 'Skip the server entirely — <code>go get</code> the engine and run the database in-process. Keyed CRUD, CAS, secondary indexes, and in-process <code>Watch</code>.'],
  ['🐳', 'Docker & Compose', 'Pull <code>ghcr.io/srjn45/scriva</code> or <code>docker compose up</code>. Data persists in a named volume; REST and gRPC ports exposed and ready.'],
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ScrivaDB — a file-based document database</title>
    <meta name="description" content="A lightweight, append-only, file-based document database. Human-readable NDJSON storage, gRPC + REST from one binary, an embeddable Go engine, secondary indexes, replication, and 7 client SDKs. MIT licensed." />
    <link rel="icon" href={`${base}favicon.svg`} />
    <meta property="og:title" content="ScrivaDB — a file-based document database" />
    <meta property="og:description" content="Append-only NDJSON storage, gRPC + REST from one binary, an embeddable Go engine. One small binary, zero dependencies." />
    <meta property="og:image" content="https://srjn45.github.io/scriva/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <!-- ===== nav ===== -->
    <nav class="nav">
      <div class="wrap nav-inner">
        <a class="brand" href={base}><span class="caret">▤</span> ScrivaDB</a>
        <div class="nav-links">
          <a class="hide-sm" href="#features">Features</a>
          <a class="hide-sm" href="#engine">How it works</a>
          <a href={`${base}start/what-is-scriva/`}>Docs</a>
          <a class="hide-sm" href={gh}>GitHub</a>
          <a class="nav-cta" href={`${base}start/install/`}>Install</a>
        </div>
      </div>
    </nav>

    <!-- ===== hero ===== -->
    <header class="section hero">
      <div class="wrap">
        <span class="pill"><span class="dot"></span> Open source · MIT · v1.0 API frozen</span>
        <h1>A file-based<br /><span class="grad">document database.</span></h1>
        <p class="lede">ScrivaDB stores each collection as append-only NDJSON — human-readable, one
          JSON object per line. Get a durable document store with gRPC + REST from a single Go
          binary, or embed the engine directly in your program. No daemon, no external runtime, no
          hidden state.</p>
        <div class="cta-row">
          <a class="btn btn-primary" href={`${base}start/quickstart/`}>Get started →</a>
          <a class="btn btn-ghost" href={gh}>★ Star on GitHub</a>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <span class="tl r"></span><span class="tl y"></span><span class="tl g"></span>
            <span class="tt">zsh — scriva</span>
          </div>
<pre class="terminal-body"><span class="prompt">$</span> <span class="cmd">scriva serve --data ./data --api-key dev-key &amp;</span>
<span class="prompt">$</span> <span class="cmd">scriva-cli insert users '&#123;"name":"alice","age":30&#125;' --api-key dev-key</span>
  <span class="ok">✓</span> id=01J8... <span class="muted">key=01J8... rev=1</span>

<span class="prompt">$</span> <span class="cmd">scriva-cli find users '&#123;"field":"name","op":"eq","value":"alice"&#125;'</span>
  <span class="tool">▶ index hit</span> <span class="muted">users.name (1 row scanned, 1 returned)</span>
  <span class="key">&#123;</span><span class="str">"name"</span>: <span class="str">"alice"</span>, <span class="str">"age"</span>: 30<span class="key">&#125;</span>

<span class="prompt">$</span> <span class="cmd">tail -1 data/users/000001.ndjson</span>  <span class="muted"># it's just text on disk</span>
  <span class="muted">&#123;"id":"01J8...","key":"01J8...","rev":1,"data":&#123;...&#125;,"crc":"a1b2"&#125;</span> <span class="cursor"></span></pre>
        </div>
      </div>
    </header>

    <!-- ===== value props ===== -->
    <section class="section" id="features">
      <div class="wrap">
        <p class="eyebrow">Why ScrivaDB</p>
        <h2>Persistence without the operational weight</h2>
        <p class="lede">When you need a real document store but standing up PostgreSQL or MongoDB is
          overkill — and you'd like to still be able to <code>cat</code> your data.</p>
        <div class="grid cols-4" style="margin-top:28px">
          {values.map(([ico, title, body]) => (
            <div class="card">
              <span class="ico">{ico}</span>
              <h3>{title}</h3>
              <p set:html={body}></p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== engine / how it works ===== -->
    <section class="section" id="engine">
      <div class="wrap">
        <p class="eyebrow">How it works</p>
        <h2>An append-only engine with real indexes</h2>
        <p class="lede">Writes append to a segment log; a background compactor merges and dedups
          sealed segments; an in-memory id index and per-field secondary indexes keep reads fast.</p>

        <div class="dash" style="margin-top:28px">
          <!-- storage layers -->
          <div class="panel span-8">
            <div class="panel-title">
              <h3>Storage engine</h3>
              <span class="badge live">crc32c-verified</span>
            </div>
            <ul class="tierlist">
              {layers.map(([color, name, desc]) => (
                <li>
                  <span class="tier-dot" style={`background:${color}`}></span>
                  <span class="tier-name">{name}</span>
                  <span class="tier-desc">{desc}</span>
                </li>
              ))}
            </ul>
            <p class="metric-sub" style="margin-top:16px">Records carry a <code>key</code>, a
              monotonic <code>rev</code>, and a <code>crc</code>. A limited <code>Find</code> is
              bounded by the <em>page size</em>, not the collection size, and streams rows as it
              reads — with keyset pagination that covers every row exactly once.</p>
          </div>

          <!-- SDK count -->
          <div class="panel span-4">
            <div class="panel-title"><h3>Over the wire</h3></div>
            <div class="metric"><span class="num">7</span><span class="unit">client SDKs</span></div>
            <div class="chips" style="margin-top:14px">
              <span class="chip">Python</span><span class="chip">JS/TS</span><span class="chip">PHP</span>
              <span class="chip">Java</span><span class="chip">Ruby</span><span class="chip">Rust</span>
              <span class="chip">C#</span>
            </div>
            <p class="metric-sub" style="margin-top:14px">Plus a generated <code>OpenAPI</code> spec
              for any other language.</p>
          </div>

          <!-- durability modes -->
          <div class="panel span-6">
            <div class="panel-title"><h3>Durability modes</h3></div>
            <div class="modebar">
              <div class="mode"><span class="k">none</span><span class="v">OS flush · fastest</span></div>
              <div class="mode active"><span class="k">interval</span><span class="v">fsync on a timer</span></div>
              <div class="mode"><span class="k">always</span><span class="v">fsync per write</span></div>
            </div>
            <p class="metric-sub" style="margin-top:14px">Trade throughput against your crash-loss
              window with <code>--sync</code>. The embedded façade defaults to <code>interval</code>
              (~1s).</p>
          </div>

          <!-- replication / scale -->
          <div class="panel span-6">
            <div class="panel-title"><h3>Replication & scale</h3></div>
            <div class="bars">
              <div class="bar-row"><span class="lbl">Leader</span><span class="bar-track"><span class="bar-fill" style="width:100%"></span></span><span class="val">read + write</span></div>
              <div class="bar-row"><span class="lbl">Followers</span><span class="bar-track"><span class="bar-fill" style="width:78%"></span></span><span class="val">read replicas</span></div>
              <div class="bar-row"><span class="lbl">Failover</span><span class="bar-track"><span class="bar-fill" style="width:52%"></span></span><span class="val">manual promote</span></div>
            </div>
            <p class="metric-sub" style="margin-top:14px">A follower bootstraps from a snapshot then
              tails the leader's committed writes by global <code>LSN</code> — resumable, no gaps or
              dupes. Bound staleness by diffing applied vs leader LSN.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== deploy modes ===== -->
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">Two binaries, three ways to run</p>
        <h2>Server, embedded, or containerized</h2>
        <div class="providers" style="margin-top:26px">
          {deploys.map(([ico, title, body]) => (
            <div class="card provider">
              <span class="ico">{ico}</span>
              <h3>{title}</h3>
              <p set:html={body}></p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== capabilities / API ===== -->
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">The API surface</p>
        <h2>More than a key-value store</h2>
        <p class="lede">Keyed CRUD with caller-supplied string keys, insert-or-replace upsert, and
          revision-checked compare-and-swap — plus streaming queries, aggregations, TTL, optimistic
          transactions, and live <code>Watch</code> subscriptions.</p>
        <div class="chips" style="margin-top:22px">
          {api.map((t) => (<span class="chip"><span class="k">{t}</span></span>))}
        </div>
      </div>
    </section>

    <!-- ===== docs links ===== -->
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">Explore</p>
        <h2>Everything ScrivaDB does</h2>
        <div class="linkgrid" style="margin-top:24px">
          {features.map(([label, slug]) => (
            <a href={`${base}${slug}/`}>{label}<span class="arw">→</span></a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== quickstart ===== -->
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">Quickstart</p>
        <h2>Up in under a minute</h2>
<pre class="qs-pre"><span class="muted"># start the server (or: docker compose up -d)</span>
scriva serve --data ./data --api-key dev-key

<span class="muted"># insert, then query — via the CLI over the Unix socket</span>
scriva-cli insert users <span class="str">'&#123;"name":"alice","age":30&#125;'</span> --api-key dev-key
scriva-cli find   users <span class="str">'&#123;"field":"age","op":"gt","value":18&#125;'</span> --api-key dev-key

<span class="muted"># or embed it directly in Go — no server at all</span>
go get github.com/srjn45/scriva/filedb</pre>
        <div class="cta-row" style="justify-content:flex-start;margin-top:24px">
          <a class="btn btn-primary" href={`${base}start/install/`}>Install guide →</a>
          <a class="btn btn-ghost" href={`${base}start/what-is-scriva/`}>Read the docs</a>
        </div>
      </div>
    </section>

    <!-- ===== footer ===== -->
    <footer class="foot">
      <div class="wrap">
        <a href={`${base}start/what-is-scriva/`}>Docs</a> ·
        <a href={gh}>GitHub</a> ·
        <a href={`${base}reference/api/`}>API</a> ·
        MIT
        <p class="fine">ScrivaDB is an independent open-source project. It is the right tool for
          single-machine, human-readable persistence — not for datasets too large to compact on one
          node, complex joins, or automatic multi-node consensus. Use at your own risk. All product
          names are trademarks of their respective owners.</p>
      </div>
    </footer>
  </body>
</html>
