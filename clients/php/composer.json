{
  "name": "srjn45/scriva",
  "description": "Official PHP client for ScrivaDB — a file-based document database with a gRPC API",
  "type": "library",
  "version": "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "srjn45",
      "homepage": "https://github.com/srjn45"
    }
  ],
  "keywords": [
    "scriva",
    "grpc",
    "database",
    "client",
    "document-store"
  ],
  "homepage": "https://github.com/srjn45/scriva",
  "require": {
    "php": ">=8.1",
    "grpc/grpc": "^1.56",
    "google/protobuf": "^3.25"
  },
  "autoload": {
    "psr-4": {
      "ScrivaDB\\": "src/",
      "Scriva\\": "src/Proto/Scriva/",
      "GPBMetadata\\": "src/Proto/GPBMetadata/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  },
  "support": {
    "issues": "https://github.com/srjn45/scriva/issues",
    "source": "https://github.com/srjn45/scriva"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
