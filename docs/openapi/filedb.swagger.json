    "v1AggregateOp": {
      "type": "string",
      "enum": [
        "AGGREGATE_OP_UNSPECIFIED",
        "AGG_COUNT",
        "AGG_SUM",
        "AGG_AVG",
        "AGG_MIN",
        "AGG_MAX"
      ],
      "default": "AGGREGATE_OP_UNSPECIFIED",
      "description": "AggregateOp names a numeric aggregation to compute per group over the request's\nnumeric `field`. COUNT (the per-group record count) is always returned and need\nnot be listed. Any of SUM/AVG/MIN/MAX requires `field` to be set.\n\n - AGG_COUNT: per-group record count (always returned)\n - AGG_SUM: sum of numeric field values\n - AGG_AVG: mean of numeric field values\n - AGG_MIN: smallest numeric field value\n - AGG_MAX: largest numeric field value"
    },
    "v1AggregateResponse": {
      "type": "object",
      "properties": {
        "groupValue": {
          "description": "The group_by field's value for this group, type-preserved (number, string,\nbool). Null for the whole-set group and for records missing the group field."
        },
        "count": {
          "type": "string",
          "format": "uint64",
          "description": "Records in this group (post-filter). Always populated."
        },
        "sum": {
          "type": "number",
          "format": "double",
          "description": "Numeric aggregates over `field` across this group's records that carried a\nnumeric value. Meaningful only when `numeric` is true."
        },
        "avg": {
          "type": "number",
          "format": "double"
        },
        "min": {
          "type": "number",
          "format": "double"
        },
        "max": {
          "type": "number",
          "format": "double"
        },
        "numeric": {
          "type": "boolean",
          "description": "numeric is true when at least one record in the group carried a numeric\n`field`; when false the sum/avg/min/max above are zero and meaningless (e.g.\na count-only aggregation, or a group where the field was absent/non-numeric)."
        }
      },
      "description": "AggregateResponse is one group's result. For a grouped request there is one per\ndistinct group_by value, streamed in ascending group order; for an ungrouped\nrequest there is exactly one, carrying a null group_value."
    },
