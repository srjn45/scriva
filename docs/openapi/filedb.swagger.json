        }
      }
    },
    "v1FieldFilter": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "$ref": "#/definitions/v1FilterOp"
        },
        "value": {
          "type": "string",
          "title": "JSON-encoded value for comparison"
        }
      }
    },
    "v1Filter": {
      "type": "object",
      "properties": {
        "field": {
          "$ref": "#/definitions/v1FieldFilter"
        },
        "and": {
          "$ref": "#/definitions/v1AndFilter"
        },
        "or": {
          "$ref": "#/definitions/v1OrFilter"
        }
      },
      "description": "A composable filter node."
    },
    "v1FilterOp": {
      "type": "string",
      "enum": [
        "FILTER_OP_UNSPECIFIED",
        "EQ",
        "NEQ",
        "GT",
        "GTE",
        "LT",
        "LTE",
        "CONTAINS",
        "REGEX"
      ],
      "default": "FILTER_OP_UNSPECIFIED",
      "title": "- EQ: equal\n - NEQ: not equal\n - GT: greater than\n - GTE: greater than or equal\n - LT: less than\n - LTE: less than or equal\n - CONTAINS: string contains\n - REGEX: regular expression match"
    },
    "v1FindResponse": {
      "type": "object",
      "properties": {
        "record": {
          "$ref": "#/definitions/v1Record"
        }
      }
    },
    "v1InsertManyResponse": {
      "type": "object",
      "properties": {
        "ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uint64"
          }
        }
      }
    },
    "v1InsertResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uint64"
        },
        "dateAdded": {
          "type": "string"
        },
        "key": {
          "type": "string",
          "description": "Caller-supplied string key (empty for a keyless insert) and the record's\nrevision. A fresh insert always starts at rev 1."
        },
        "rev": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1ListCollectionsResponse": {
      "type": "object",
      "properties": {
        "names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "v1ListIndexesResponse": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "v1OrFilter": {
      "type": "object",
      "properties": {
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Filter"
          }
        }
      }
    },
    "v1Record": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uint64"
        },
        "data": {
          "type": "object"
        },
        "dateAdded": {
          "type": "string",
          "format": "date-time"
        },
        "dateModified": {
          "type": "string",
          "format": "date-time"
        },
        "key": {
          "type": "string",
          "description": "Caller-supplied string primary key, empty for records inserted without one."
        },
        "rev": {
          "type": "string",
          "format": "uint64",
          "description": "Monotonic per-record revision, bumped on every write. Fresh records start\nat 1. Feed it to UpdateIfRev for optimistic-concurrency updates."
        }
      }
    },
    "v1UpdateIfRevResponse": {
      "type": "object",
      "properties": {
        "swapped": {
          "type": "boolean",
          "description": "swapped is true when expected_rev matched and the update applied; false —\nnever an error — when the revision was stale or no live record carries key."
        },
        "record": {
          "$ref": "#/definitions/v1Record",
          "description": "The resulting record when swapped is true; unset otherwise."
        }
      }
    },
    "v1UpdateResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uint64"
        },
        "dateModified": {
          "type": "string"
        },
        "key": {
          "type": "string",
          "description": "Caller-supplied string key (empty for a keyless update) and the record's\nrevision after the write."
        },
        "rev": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1UpsertResponse": {
      "type": "object",
      "properties": {
        "record": {
          "$ref": "#/definitions/v1Record",
          "description": "The resulting record, including its key and (incremented on replace) rev."
        }
      }
    },
    "v1WatchEvent": {
      "type": "object",
      "properties": {
        "op": {
          "$ref": "#/definitions/v1WatchOp"
        },
        "collection": {
          "type": "string"
        },
        "record": {
          "$ref": "#/definitions/v1Record"
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1WatchOp": {
      "type": "string",
      "enum": [
        "WATCH_OP_UNSPECIFIED",
        "INSERTED",
        "UPDATED",
        "DELETED",
        "OVERFLOW"
      ],
      "default": "WATCH_OP_UNSPECIFIED",
      "description": " - OVERFLOW: OVERFLOW signals that the server dropped events because this subscriber\nfell behind. The client missed writes and should resync. No record is set."
    }
  }
}
