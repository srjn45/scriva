  "definitions": {
    "FileDBCompactBody": {
      "type": "object"
    },
    "FileDBEnsureIndexBody": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string"
        }
      }
    },
    "FileDBFindBody": {
      "type": "object",
      "properties": {
        "filter": {
          "$ref": "#/definitions/v1Filter"
        },
        "limit": {
          "type": "integer",
          "format": "int64",
          "title": "0 = no limit"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        },
        "orderBy": {
          "type": "string",
          "title": "field name"
        },
        "descending": {
          "type": "boolean"
        }
      }
    },
    "FileDBInsertBody": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "description": "Optional per-record TTL, in seconds. When \u003e 0, the record expires this long\nafter insertion, overriding any collection default. 0 (the default)\napplies the collection's default TTL, if any."
        },
        "key": {
          "type": "string",
          "description": "Optional caller-supplied string primary key (keyed Create). When set, the\nrecord is inserted under this key and a key already held by a live record\nis rejected with ALREADY_EXISTS. Empty (the default) preserves the existing\nserver-assigned-id behaviour. A keyed insert does not participate in\ntransactions or per-record TTL."
        }
      }
    },
    "FileDBInsertManyBody": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "description": "Optional per-record TTL, in seconds, applied to every record in the batch.\nSame semantics as InsertRequest.ttl_seconds."
        }
      }
    },
    "FileDBUpdateBody": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "description": "Optional per-record TTL, in seconds, resetting the record's deadline to\nthis long from now. When \u003e 0 it overrides the collection default; 0 (the\ndefault) re-applies the collection default TTL, if any."
        }
      }
    },
    "FileDBUpdateByKeyBody": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        }
      }
    },
    "FileDBUpdateIfRevBody": {
      "type": "object",
      "properties": {
        "expectedRev": {
          "type": "string",
          "format": "uint64"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "FileDBUpsertBody": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "FileDBWatchBody": {
      "type": "object",
      "properties": {
        "filter": {
          "$ref": "#/definitions/v1Filter",
          "title": "optional: only receive events matching this filter"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "protobufNullValue": {
      "type": "string",
      "enum": [
        "NULL_VALUE"
      ],
      "default": "NULL_VALUE",
      "description": "`NullValue` is a singleton enumeration to represent the null value for the\n`Value` type union.\n\nThe JSON representation for `NullValue` is JSON `null`.\n\n - NULL_VALUE: Null value."
    },
    "rpcStatus": {
      "type": "object",
