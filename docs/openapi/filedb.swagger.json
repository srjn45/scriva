  "definitions": {
    "FileDBAggregateBody": {
      "type": "object",
      "properties": {
        "filter": {
          "$ref": "#/definitions/v1Filter",
          "description": "The same composable filter as Find. Aggregation honours it: only matching\nlive records contribute. Empty (nil) aggregates the whole collection."
        },
        "groupBy": {
          "type": "string",
          "description": "Optional group-by field. When set, one response is streamed per distinct value\nof this field; records are bucketed by that value. Empty (the default)\naggregates the whole filtered set into a single group whose group_value is\nnull."
        },
        "field": {
          "type": "string",
          "description": "Numeric field for SUM/AVG/MIN/MAX. Required when any of those aggregations is\nrequested; ignored for a pure count. Only records whose `field` is numeric\ncontribute to the numeric aggregates (AVG divides by that numeric count)."
        },
        "aggregations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/v1AggregateOp"
          },
          "description": "Which aggregations to compute. COUNT is always returned even if omitted; an\nempty list yields count-only. SUM/AVG/MIN/MAX require `field`."
        }
      }
    },
    "FileDBCompactBody": {
      "type": "object"
    },
    "FileDBEnsureIndexBody": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string"
        }
      }
    },
    "FileDBFindBody": {
      "type": "object",
      "properties": {
        "filter": {
          "$ref": "#/definitions/v1Filter"
        },
        "limit": {
          "type": "integer",
          "format": "int64",
          "title": "0 = no limit"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        },
        "orderBy": {
          "type": "string",
          "description": "Deprecated single-field sort. Superseded by order_by_fields (N3): honoured\nonly when order_by_fields is empty, and slated for removal after one release.\nMigrate `order_by:\"f\", descending:d` to `order_by_fields:[{field:\"f\", desc:d}]`.\n\nfield name"
        },
        "descending": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional field projection: when non-empty, only these top-level fields are\nreturned in each record's data. id, key and rev are always included. Empty\n(the default) returns full records. An unknown field is silently omitted."
        },
        "pageToken": {
          "type": "string",
          "description": "Opaque keyset (cursor) pagination token (N3). Empty (the default) requests\nthe first page; otherwise it must be a page_token returned by a previous Find\nand the scan seeks past the rows already returned instead of counting past\nthem (O(page), not O(offset)). Only meaningful with an ordering\n(order_by_fields or the deprecated order_by); pass the same ordering, filter,\nand limit on every page. Combine with offset=0 for keyset paging."
        },
        "orderByFields": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1OrderBy"
          },
          "description": "Multi-field, per-field-directional sort (N3). When non-empty it supersedes\nthe deprecated scalar order_by/descending. The record id is always the final\ntiebreaker, so the sort is total and pagination is stable."
        }
      }
    },
    "FileDBInsertBody": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "description": "Optional per-record TTL, in seconds. When \u003e 0, the record expires this long\nafter insertion, overriding any collection default. 0 (the default)\napplies the collection's default TTL, if any."
        },
        "key": {
          "type": "string",
          "description": "Optional caller-supplied string primary key (keyed Create). When set, the\nrecord is inserted under this key and a key already held by a live record\nis rejected with ALREADY_EXISTS. Empty (the default) preserves the existing\nserver-assigned-id behaviour. A keyed insert does not participate in\ntransactions or per-record TTL."
        }
      }
    },
